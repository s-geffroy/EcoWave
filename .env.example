ECOWAVE_MODE=strict
ECOWAVE_PILOT=2008

# Champion/challenger: a challenger dethrones the champion on >=3/6 criteria only if
# its weighted score exceeds the champion's by at least this margin (0-3 scale).
ECOWAVE_DETHRONE_MARGIN=0.30

# FRED requires an API key for web service requests.
FRED_API_KEY=replace_me

# ECB Data Portal API base endpoint.
ECB_API_BASE=https://data-api.ecb.europa.eu/service

# Later phases. Disabled in V1 Phase 1 by default.
GDELT_ENABLED=false
GDELT_API_BASE=https://api.gdeltproject.org/api/v2/doc/doc
WORLD_BANK_API_BASE=https://api.worldbank.org/v2

# Storage paths inside the container.
ECOWAVE_DB_PATH=/app/db/ecowave.db
DATA_RAW_DIR=/app/data_raw
DATA_PROCESSED_DIR=/app/data_processed
EVENTS_DIR=/app/events
REPORTS_DIR=/app/reports
FIGURES_DIR=/app/figures
ANNOTATIONS_DIR=/app/annotations
