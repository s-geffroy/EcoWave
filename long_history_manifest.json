  "variable_codes": [
    {"variable_code": "LH_GDP",    "cycle_targets": ["juglar", "kuznets", "kondratieff"], "notes": "GDP per capita — Maddison-style. Long-wave productivity proxy."},
    {"variable_code": "LH_CREDIT", "cycle_targets": ["juglar", "kuznets", "kondratieff"], "notes": "Total loans. Borio/Drehmann financial cycle driver."},
    {"variable_code": "LH_HPI",    "cycle_targets": ["kuznets"],                         "notes": "House price index. Construction / Kuznets swing."},
    {"variable_code": "LH_EQUITY", "cycle_targets": ["juglar"],                          "notes": "Equity capital gains. Short cycle."},
    {"variable_code": "LH_YIELD",  "cycle_targets": ["kondratieff"],                     "notes": "Long-term bond yield. Kondratieff price-level proxy."},
    {"variable_code": "LH_CPI",    "cycle_targets": ["kondratieff"],                     "notes": "Consumer prices. Long-wave inflation proxy."}
